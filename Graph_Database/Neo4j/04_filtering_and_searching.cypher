///////////////////////////////////////////////////////////////////////////////
// Neo4j Cypher - Filtering and Searching
// File: 04_filtering_and_searching.cypher
//
// Topics Covered
// 1. WHERE Clause
// 2. Comparison Operators
// 3. Logical Operators
//      - AND
//      - OR
//      - NOT
// 4. IN Operator
// 5. EXISTS
// 6. IS NULL
// 7. String Matching
//      - STARTS WITH
//      - ENDS WITH
//      - CONTAINS
//      - Regular Expressions (Regex)
// 8. Range Queries
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// SAMPLE DATA
///////////////////////////////////////////////////////////////////////////////

/*
Assume the database contains:

(:Person {name:'Alice', age:25, city:'London'})
(:Person {name:'Bob', age:30, city:'New York'})
(:Person {name:'Charlie', age:35, city:'London'})
(:Person {name:'David', age:22})
(:Person {name:'Emma', age:40, city:'Paris'})

(:Company {name:'Google'})
(:Company {name:'Microsoft'})

*/




///////////////////////////////////////////////////////////////////////////////
// 1. WHERE CLAUSE
///////////////////////////////////////////////////////////////////////////////

//
// WHERE filters matched results.
//
// Syntax:
//
// MATCH (...)
// WHERE condition
// RETURN ...
//
///////////////////////////////////////////////////////////////////////////////



// Find Alice

MATCH (p:Person)

WHERE p.name = 'Alice'

RETURN p;



// Find people older than 30

MATCH (p:Person)

WHERE p.age > 30

RETURN p;



// Find Google

MATCH (c:Company)

WHERE c.name = 'Google'

RETURN c;



///////////////////////////////////////////////////////////////////////////////
// 2. COMPARISON OPERATORS
///////////////////////////////////////////////////////////////////////////////

//
// =      Equal
// <>     Not Equal
// >      Greater Than
// <      Less Than
// >=     Greater Than or Equal
// <=     Less Than or Equal
//
///////////////////////////////////////////////////////////////////////////////



// Equal

MATCH (p:Person)

WHERE p.age = 25

RETURN p;



// Not Equal

MATCH (p:Person)

WHERE p.age <> 25

RETURN p;



// Greater Than

MATCH (p:Person)

WHERE p.age > 30

RETURN p;



// Less Than

MATCH (p:Person)

WHERE p.age < 30

RETURN p;



// Greater Than or Equal

MATCH (p:Person)

WHERE p.age >= 30

RETURN p;



// Less Than or Equal

MATCH (p:Person)

WHERE p.age <= 30

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 3. LOGICAL OPERATORS
///////////////////////////////////////////////////////////////////////////////

//
// Combine multiple conditions.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// AND
///////////////////////////////////////////////////////////////////////////////

//
// Both conditions must be TRUE.
//
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

p.age > 25
AND
p.city = 'London'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// OR
///////////////////////////////////////////////////////////////////////////////

//
// Either condition may be TRUE.
//
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

p.city = 'London'
OR
p.city = 'Paris'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// NOT
///////////////////////////////////////////////////////////////////////////////

//
// Negates a condition.
//
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

NOT p.city = 'London'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// COMBINING LOGICAL OPERATORS
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

(p.age >= 25 AND p.age <= 35)
AND
NOT p.city = 'Paris'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 4. IN OPERATOR
///////////////////////////////////////////////////////////////////////////////

//
// Tests whether a value exists in a list.
//
///////////////////////////////////////////////////////////////////////////////



MATCH (p:Person)

WHERE

p.city IN ['London', 'Paris']

RETURN p;



// Search multiple names

MATCH (p:Person)

WHERE

p.name IN ['Alice','Bob','Emma']

RETURN p;



// Numeric IN

MATCH (p:Person)

WHERE

p.age IN [22,25,40]

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 5. EXISTS
///////////////////////////////////////////////////////////////////////////////

//
// EXISTS checks whether a property exists.
//
// Syntax:
//
// EXISTS(variable.property)
//
///////////////////////////////////////////////////////////////////////////////



// Has email property

MATCH (p:Person)

WHERE

EXISTS(p.email)

RETURN p;



// Has city

MATCH (p:Person)

WHERE

EXISTS(p.city)

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// EXISTS FOR RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

EXISTS {
    MATCH (p)-[:WORKS_AT]->()
}

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 6. IS NULL
///////////////////////////////////////////////////////////////////////////////

//
// Check missing values.
//
///////////////////////////////////////////////////////////////////////////////



// Missing city

MATCH (p:Person)

WHERE

p.city IS NULL

RETURN p;



// City exists

MATCH (p:Person)

WHERE

p.city IS NOT NULL

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// Missing email
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

p.email IS NULL

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 7. STRING MATCHING
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// STARTS WITH
///////////////////////////////////////////////////////////////////////////////

//
// Names beginning with A
//
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

p.name STARTS WITH 'A'

RETURN p;



// Companies starting with G

MATCH (c:Company)

WHERE

c.name STARTS WITH 'G'

RETURN c;



///////////////////////////////////////////////////////////////////////////////
// ENDS WITH
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

p.name ENDS WITH 'e'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// CONTAINS
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

p.name CONTAINS 'ar'

RETURN p;



// Company contains "soft"

MATCH (c:Company)

WHERE

c.name CONTAINS 'soft'

RETURN c;



///////////////////////////////////////////////////////////////////////////////
// REGULAR EXPRESSIONS
///////////////////////////////////////////////////////////////////////////////

//
// =~
//
///////////////////////////////////////////////////////////////////////////////



// Starts with A

MATCH (p:Person)

WHERE

p.name =~ 'A.*'

RETURN p;



// Ends with e

MATCH (p:Person)

WHERE

p.name =~ '.*e'

RETURN p;



// Exactly five letters

MATCH (p:Person)

WHERE

p.name =~ '.....'

RETURN p;



// Contains only lowercase letters

MATCH (p:Person)

WHERE

p.name =~ '[a-z]+'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// CASE-INSENSITIVE SEARCH
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE

p.name =~ '(?i)alice'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 8. RANGE QUERIES
///////////////////////////////////////////////////////////////////////////////

//
// Find values within ranges.
//
///////////////////////////////////////////////////////////////////////////////



// Between 20 and 30

MATCH (p:Person)

WHERE

p.age >= 20
AND
p.age <= 30

RETURN p;



// Alternative syntax

MATCH (p:Person)

WHERE

p.age > 20
AND
p.age < 40

RETURN p;



// Names between A and M (alphabetically)

MATCH (p:Person)

WHERE

p.name >= 'A'
AND
p.name < 'N'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// FILTER RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(p:Person)-[r:FRIEND]->(friend)

WHERE

r.since >= 2020

RETURN

p,
friend,
r;



///////////////////////////////////////////////////////////////////////////////
// FILTER MULTIPLE LABELS
///////////////////////////////////////////////////////////////////////////////

MATCH (e:Person:Employee)

WHERE

e.department = 'IT'

RETURN e;



///////////////////////////////////////////////////////////////////////////////
// PRACTICE EXERCISES
///////////////////////////////////////////////////////////////////////////////

//
// Exercise 1
// Find people older than 25.
//
MATCH (p:Person)

WHERE p.age > 25

RETURN p;



//
// Exercise 2
// Find people from London.
//
MATCH (p:Person)

WHERE p.city = 'London'

RETURN p;



//
// Exercise 3
// Find people from London or Paris.
//
MATCH (p:Person)

WHERE p.city IN ['London','Paris']

RETURN p;



//
// Exercise 4
// Find names starting with C.
//
MATCH (p:Person)

WHERE p.name STARTS WITH 'C'

RETURN p;



//
// Exercise 5
// Find names ending with a.
//
MATCH (p:Person)

WHERE p.name ENDS WITH 'a'

RETURN p;



//
// Exercise 6
// Find names containing "li".
//
MATCH (p:Person)

WHERE p.name CONTAINS 'li'

RETURN p;



//
// Exercise 7
// Find people without city.
//
MATCH (p:Person)

WHERE p.city IS NULL

RETURN p;



//
// Exercise 8
// Find people whose age is between 25 and 35.
//
MATCH (p:Person)

WHERE

p.age >= 25
AND
p.age <= 35

RETURN p;



//
// Exercise 9
// Find people with email property.
//
MATCH (p:Person)

WHERE EXISTS(p.email)

RETURN p;



//
// Exercise 10
// Find names beginning with A or B.
//
MATCH (p:Person)

WHERE

p.name =~ '^[AB].*'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// CHEAT SHEET
///////////////////////////////////////////////////////////////////////////////

//
// WHERE
//
// MATCH (...) WHERE condition RETURN ...
//
//
//
// Comparison Operators
//
// =
// <>
// >
// <
// >=
// <=
//
//
//
// Logical Operators
//
// AND
// OR
// NOT
//
//
//
// Membership
//
// IN
//
//
//
// Null Check
//
// IS NULL
// IS NOT NULL
//
//
//
// Property Exists
//
// EXISTS(property)
//
//
//
// String Matching
//
// STARTS WITH
// ENDS WITH
// CONTAINS
// =~
//
//
//
// Range
//
// age >= 20 AND age <= 30
//
///////////////////////////////////////////////////////////////////////////////



