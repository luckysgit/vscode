///////////////////////////////////////////////////////////////////////////////
// Neo4j Cypher - Updating and Deleting Data
// File: 05_updating_and_deleting_data.cypher
//
// Topics Covered
// 1. SET
// 2. REMOVE
// 3. DELETE
// 4. DETACH DELETE
// 5. Property Updates
// 6. Label Updates
// 7. Bulk Updates
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// SAMPLE DATA
///////////////////////////////////////////////////////////////////////////////

/*

(:Person {
    name:'Alice',
    age:25,
    city:'London'
})

(:Person {
    name:'Bob',
    age:30,
    city:'New York'
})

(:Person {
    name:'Charlie',
    age:35
})

(:Company {name:'Google'})
(:Company {name:'Microsoft'})

(Alice)-[:WORKS_AT]->(Google)
(Bob)-[:WORKS_AT]->(Google)

*/




///////////////////////////////////////////////////////////////////////////////
// 1. SET
///////////////////////////////////////////////////////////////////////////////

//
// SET updates:
//
// • Properties
// • Labels
//
// Syntax:
//
// MATCH (...)
// SET ...
//
///////////////////////////////////////////////////////////////////////////////



// Update a single property

MATCH (p:Person {name:'Alice'})

SET p.age = 26

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// UPDATE MULTIPLE PROPERTIES
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET
    p.city = 'Paris',
    p.salary = 90000,
    p.email = 'alice@example.com'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// CREATE PROPERTY IF IT DOESN'T EXIST
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Bob'})

SET p.phone = '+1-555-1234'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// UPDATE PROPERTY USING CURRENT VALUE
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Bob'})

SET p.age = p.age + 1

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// COPY PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

SET p.fullName = p.name

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// REPLACE ALL PROPERTIES
///////////////////////////////////////////////////////////////////////////////

//
// "=" replaces ALL existing properties.
//
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Charlie'})

SET p = {
    name:'Charlie',
    age:36,
    city:'Berlin'
}

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// MERGE PROPERTIES
///////////////////////////////////////////////////////////////////////////////

//
// "+=" keeps existing properties
// and adds or updates new ones.
//
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p += {
    salary:100000,
    department:'IT'
}

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 2. REMOVE
///////////////////////////////////////////////////////////////////////////////

//
// REMOVE deletes:
//
// • Properties
// • Labels
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// REMOVE PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

REMOVE p.salary

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// REMOVE MULTIPLE PROPERTIES
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

REMOVE
    p.email,
    p.phone

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// REMOVE LABEL
///////////////////////////////////////////////////////////////////////////////

MATCH (e:Employee)

REMOVE e:Employee

RETURN e;



///////////////////////////////////////////////////////////////////////////////
// REMOVE MULTIPLE LABELS
///////////////////////////////////////////////////////////////////////////////

MATCH (m:Manager)

REMOVE
    m:Manager,
    m:Employee

RETURN m;



///////////////////////////////////////////////////////////////////////////////
// 3. DELETE
///////////////////////////////////////////////////////////////////////////////

//
// DELETE removes:
//
// • Nodes
// • Relationships
//
// Node must NOT have relationships.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// DELETE RELATIONSHIP
///////////////////////////////////////////////////////////////////////////////

MATCH

(a:Person {name:'Alice'})

-[r:WORKS_AT]->

(c:Company {name:'Google'})

DELETE r;



///////////////////////////////////////////////////////////////////////////////
// VERIFY
///////////////////////////////////////////////////////////////////////////////

MATCH ()-[r]->()

RETURN r;



///////////////////////////////////////////////////////////////////////////////
// DELETE NODE
///////////////////////////////////////////////////////////////////////////////

//
// Works only if node has NO relationships.
//
///////////////////////////////////////////////////////////////////////////////

CREATE (:Temp {name:'Temporary Node'});

MATCH (t:Temp)

DELETE t;



///////////////////////////////////////////////////////////////////////////////
// DELETE MULTIPLE NODES
///////////////////////////////////////////////////////////////////////////////

MATCH (b:Book)

DELETE b;



///////////////////////////////////////////////////////////////////////////////
// DELETE MULTIPLE RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

MATCH ()-[r:FRIEND]->()

DELETE r;



///////////////////////////////////////////////////////////////////////////////
// 4. DETACH DELETE
///////////////////////////////////////////////////////////////////////////////

//
// Deletes:
//
// Node
// +
// Every relationship attached to it.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// DELETE PERSON WITH RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Bob'})

DETACH DELETE p;



///////////////////////////////////////////////////////////////////////////////
// DELETE COMPANY
///////////////////////////////////////////////////////////////////////////////

MATCH (c:Company {name:'Google'})

DETACH DELETE c;



///////////////////////////////////////////////////////////////////////////////
// DELETE ENTIRE DATABASE
///////////////////////////////////////////////////////////////////////////////

//
// WARNING!
// Removes EVERYTHING.
//
///////////////////////////////////////////////////////////////////////////////

/*

MATCH (n)

DETACH DELETE n;

*/



///////////////////////////////////////////////////////////////////////////////
// 5. PROPERTY UPDATES
///////////////////////////////////////////////////////////////////////////////

//
// Update different property types.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// STRING PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p.city = 'Tokyo'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// INTEGER PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p.age = 30

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// BOOLEAN PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p.active = true

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// FLOAT PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p.salary = 85000.75

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// LIST PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p.skills = ['Python','Neo4j','Cypher']

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// APPEND TO LIST
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p.skills = p.skills + 'GraphQL'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// REMOVE ITEM FROM LIST
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p.skills =
    [skill IN p.skills WHERE skill <> 'GraphQL']

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 6. LABEL UPDATES
///////////////////////////////////////////////////////////////////////////////

//
// Labels classify nodes.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// ADD LABEL
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET p:Employee

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// ADD MULTIPLE LABELS
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

SET
    p:Manager,
    p:Admin

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// REMOVE LABEL
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

REMOVE p:Admin

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// CHANGE LABEL
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person {name:'Alice'})

REMOVE p:Employee

SET p:Consultant

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 7. BULK UPDATES
///////////////////////////////////////////////////////////////////////////////

//
// Update many nodes at once.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// GIVE EVERYONE A COUNTRY
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

SET p.country = 'USA'

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// INCREASE EVERYONE'S AGE
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

SET p.age = p.age + 1

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// GIVE EMPLOYEES A BONUS
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Employee)

SET p.salary = p.salary + 5000

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// UPDATE USING WHERE
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE p.age >= 30

SET p.senior = true

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// UPDATE MULTIPLE LABELS
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

SET p:ActiveUser

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// REMOVE PROPERTY FROM EVERY NODE
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

REMOVE p.phone

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// BULK PROPERTY MERGE
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

SET p += {
    verified:true,
    updated:true
}

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// PRACTICE EXERCISES
///////////////////////////////////////////////////////////////////////////////

//
// Exercise 1
// Update Alice's city.
//
MATCH (p:Person {name:'Alice'})

SET p.city = 'Sydney'

RETURN p;



//
// Exercise 2
// Increase Bob's age by 5.
//
MATCH (p:Person {name:'Bob'})

SET p.age = p.age + 5

RETURN p;



//
// Exercise 3
// Remove Charlie's city property.
//
MATCH (p:Person {name:'Charlie'})

REMOVE p.city

RETURN p;



//
// Exercise 4
// Add Employee label.
//
MATCH (p:Person)

SET p:Employee

RETURN p;



//
// Exercise 5
// Remove Employee label.
//
MATCH (p:Employee)

REMOVE p:Employee

RETURN p;



//
// Exercise 6
// Delete FRIEND relationships.
//
MATCH ()-[r:FRIEND]->()

DELETE r;



//
// Exercise 7
// Delete every Company.
//
MATCH (c:Company)

DETACH DELETE c;



//
// Exercise 8
// Give everyone "active=true"
//
MATCH (p:Person)

SET p.active = true

RETURN p;



//
// Exercise 9
// Remove phone property from everyone.
//
MATCH (p:Person)

REMOVE p.phone

RETURN p;



//
// Exercise 10
// Delete every Temp node.
//
MATCH (t:Temp)

DELETE t;



///////////////////////////////////////////////////////////////////////////////
// CHEAT SHEET
///////////////////////////////////////////////////////////////////////////////

//
// UPDATE PROPERTY
//
// SET p.age = 30
//
//
//
// UPDATE MULTIPLE
//
// SET p.city='London',
//     p.age=35
//
//
//
// MERGE PROPERTIES
//
// SET p += {salary:5000}
//
//
//
// REPLACE PROPERTIES
//
// SET p = {name:'Alice'}
//
//
//
// REMOVE PROPERTY
//
// REMOVE p.salary
//
//
//
// ADD LABEL
//
// SET p:Employee
//
//
//
// REMOVE LABEL
//
// REMOVE p:Employee
//
//
//
// DELETE RELATIONSHIP
//
// DELETE r
//
//
//
// DELETE NODE
//
// DELETE n
//
// (Only if no relationships)
//
//
//
// DELETE NODE + RELATIONSHIPS
//
// DETACH DELETE n
//
//
//
// BULK UPDATE
//
// MATCH (p:Person)
// SET p.active=true
//
///////////////////////////////////////////////////////////////////////////////



