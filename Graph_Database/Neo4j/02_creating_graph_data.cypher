///////////////////////////////////////////////////////////////////////////////
// Neo4j Cypher - Creating Graph Data
// File: 02_creating_graph_data.cypher
//
// Topics Covered
// 1. CREATE
// 2. CREATE Nodes
// 3. CREATE Relationships
// 4. Multiple Node Creation
// 5. Properties
// 6. Labels
// 7. MERGE
//      - Node Merge
//      - Relationship Merge
//      - Avoiding Duplicates
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// CLEAN DATABASE (Optional)
//
// Uncomment if you want a fresh database.
//
// WARNING: Deletes EVERYTHING.
///////////////////////////////////////////////////////////////////////////////

/*
MATCH (n)
DETACH DELETE n;
*/



///////////////////////////////////////////////////////////////////////////////
// 1. CREATE
///////////////////////////////////////////////////////////////////////////////

//
// CREATE is used to insert new nodes and relationships.
//
// Syntax:
//
// CREATE (variable:Label {property:value})
//
// Every execution of CREATE inserts NEW data.
// It never checks whether the data already exists.
//
///////////////////////////////////////////////////////////////////////////////


// Create a single node

CREATE (p:Person);



// Verify

MATCH (p:Person)
RETURN p;



///////////////////////////////////////////////////////////////////////////////
// 2. CREATE NODES
///////////////////////////////////////////////////////////////////////////////

//
// Nodes represent entities.
//
// Examples:
// Person
// Company
// Product
// Movie
// City
//
///////////////////////////////////////////////////////////////////////////////


// Create a Person node

CREATE (p:Person);



// Create a Company node

CREATE (c:Company);



// Create a City node

CREATE (city:City);



// Verify

MATCH (n)
RETURN n;



///////////////////////////////////////////////////////////////////////////////
// CREATE NODE WITH PROPERTIES
///////////////////////////////////////////////////////////////////////////////

//
// Properties store information about a node.
//
// Syntax:
//
// CREATE (:Label {
//      property1:value1,
//      property2:value2
// })
//
///////////////////////////////////////////////////////////////////////////////


// Create a person with properties

CREATE
(
    p:Person
    {
        name: "Alice",
        age: 25,
        email: "alice@email.com"
    }
);



// Verify

MATCH (p:Person)
RETURN p;



///////////////////////////////////////////////////////////////////////////////
// CREATE MULTIPLE DIFFERENT NODES
///////////////////////////////////////////////////////////////////////////////

CREATE
    (a:Person {name:'Bob'}),
    (b:Company {name:'Google'}),
    (c:City {name:'London'});



MATCH (n)
RETURN n;



///////////////////////////////////////////////////////////////////////////////
// 3. CREATE RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

//
// Relationships connect nodes.
//
// Syntax:
//
// (A)-[:TYPE]->(B)
//
///////////////////////////////////////////////////////////////////////////////


// First find existing nodes

MATCH
    (alice:Person {name:'Alice'}),
    (google:Company {name:'Google'})


// Create relationship

CREATE
    (alice)-[:WORKS_AT]->(google);



// Verify

MATCH (a)-[r]->(b)
RETURN a,r,b;



///////////////////////////////////////////////////////////////////////////////
// CREATE MULTIPLE RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

//
// One node can have multiple relationships.
//
///////////////////////////////////////////////////////////////////////////////


// Create Charlie

CREATE
    (:Person {name:'Charlie', age:28});



// Connect Charlie

MATCH
    (charlie:Person {name:'Charlie'}),
    (google:Company {name:'Google'}),
    (alice:Person {name:'Alice'})

CREATE
    (charlie)-[:WORKS_AT]->(google),
    (charlie)-[:FRIEND]->(alice);



// Verify

MATCH (a)-[r]->(b)
RETURN a,r,b;



///////////////////////////////////////////////////////////////////////////////
// CREATE RELATIONSHIP WITH PROPERTIES
///////////////////////////////////////////////////////////////////////////////

//
// Relationships can also store properties.
//
///////////////////////////////////////////////////////////////////////////////


MATCH
    (alice:Person {name:'Alice'}),
    (bob:Person {name:'Bob'})

CREATE
    (alice)-[:FRIEND
    {
        since:2020,
        status:"Best Friends"
    }]->(bob);



// Verify

MATCH ()-[r:FRIEND]->()
RETURN r;



///////////////////////////////////////////////////////////////////////////////
// 4. MULTIPLE NODE CREATION
///////////////////////////////////////////////////////////////////////////////

//
// CREATE can create many nodes at once.
//
///////////////////////////////////////////////////////////////////////////////

CREATE

(:Person {name:'David',age:22}),

(:Person {name:'Emma',age:35}),

(:Person {name:'Frank',age:31}),

(:Person {name:'Grace',age:29});



MATCH (p:Person)
RETURN p;



///////////////////////////////////////////////////////////////////////////////
// CREATE MULTIPLE CONNECTED NODES
///////////////////////////////////////////////////////////////////////////////

//
// Entire graph can be created in one statement.
//
///////////////////////////////////////////////////////////////////////////////

CREATE

(alex:Person {name:'Alex'})

-[:WORKS_AT]->

(company:Company {name:'Microsoft'});



MATCH (n)
RETURN n;



///////////////////////////////////////////////////////////////////////////////
// 5. PROPERTIES
///////////////////////////////////////////////////////////////////////////////

//
// Properties are key-value pairs.
//
// Supported types:
//
// String
// Integer
// Float
// Boolean
// List
// Date
//
///////////////////////////////////////////////////////////////////////////////


// Different property types

CREATE

(
    p:Person
    {
        name:"John",
        age:30,
        salary:85000.50,
        active:true,
        skills:["Python","Neo4j","Cypher"]
    }
);



MATCH (p:Person {name:"John"})
RETURN p;



///////////////////////////////////////////////////////////////////////////////
// ACCESS PROPERTIES
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

RETURN

p.name,
p.age,
p.salary,
p.skills;



///////////////////////////////////////////////////////////////////////////////
// 6. LABELS
///////////////////////////////////////////////////////////////////////////////

//
// Labels categorize nodes.
//
// A node may have:
//
// One label
// Multiple labels
//
///////////////////////////////////////////////////////////////////////////////


// Single Label

CREATE
(
    p:Person
    {
        name:"Sam"
    }
);



// Multiple Labels

CREATE

(
    e:Person:Employee
    {
        name:"Kevin",
        department:"IT"
    }
);



// Three Labels

CREATE

(
    m:Person:Manager:Employee
    {
        name:"Sarah"
    }
);



// Find all Employees

MATCH (e:Employee)
RETURN e;



// Find all Managers

MATCH (m:Manager)
RETURN m;



///////////////////////////////////////////////////////////////////////////////
// 7. MERGE
///////////////////////////////////////////////////////////////////////////////

//
// MERGE is similar to:
//
// "Find if exists."
// "If not found, create."
//
// MERGE prevents duplicate nodes.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// NODE MERGE
///////////////////////////////////////////////////////////////////////////////

//
// First execution:
//
// Creates node.
//
// Second execution:
//
// Reuses existing node.
//
///////////////////////////////////////////////////////////////////////////////


// First run

MERGE
(
    p:Person
    {
        name:'Alice'
    }
);



// Run again

MERGE
(
    p:Person
    {
        name:'Alice'
    }
);



// Verify

MATCH (p:Person {name:'Alice'})
RETURN p;



///////////////////////////////////////////////////////////////////////////////
// DIFFERENCE BETWEEN CREATE AND MERGE
///////////////////////////////////////////////////////////////////////////////

//
// CREATE always inserts.
//
// MERGE inserts only if needed.
//
///////////////////////////////////////////////////////////////////////////////


// Creates duplicate every time

CREATE
(
    :Person
    {
        name:'Duplicate'
    }
);



// Safe

MERGE
(
    :Person
    {
        name:'Unique'
    }
);



///////////////////////////////////////////////////////////////////////////////
// RELATIONSHIP MERGE
///////////////////////////////////////////////////////////////////////////////

//
// MERGE also works for relationships.
//
///////////////////////////////////////////////////////////////////////////////

MATCH

(alice:Person {name:'Alice'}),

(google:Company {name:'Google'})

MERGE

(alice)-[:WORKS_AT]->(google);



// Execute multiple times.
//
// Only ONE relationship will exist.



MATCH (a)-[r:WORKS_AT]->(b)

RETURN a,r,b;



///////////////////////////////////////////////////////////////////////////////
// MERGE ENTIRE PATTERN
///////////////////////////////////////////////////////////////////////////////

//
// MERGE checks the complete pattern.
//
///////////////////////////////////////////////////////////////////////////////

MERGE

(alice:Person {name:'Alice'})

-[:KNOWS]->

(bob:Person {name:'Bob'});



MATCH (a)-[r:KNOWS]->(b)

RETURN a,r,b;



///////////////////////////////////////////////////////////////////////////////
// AVOIDING DUPLICATES
///////////////////////////////////////////////////////////////////////////////

//
// Bad Practice
///////////////////////////////////////////////////////////////////////////////

CREATE (:Person {name:'Tom'});

CREATE (:Person {name:'Tom'});

CREATE (:Person {name:'Tom'});



// Result:
//
// Three Tom nodes.
//
// Verify

MATCH (p:Person {name:'Tom'})
RETURN p;



///////////////////////////////////////////////////////////////////////////////
// Good Practice
///////////////////////////////////////////////////////////////////////////////

MERGE (:Person {name:'Jerry'});

MERGE (:Person {name:'Jerry'});

MERGE (:Person {name:'Jerry'});



// Verify

MATCH (p:Person {name:'Jerry'})
RETURN p;



///////////////////////////////////////////////////////////////////////////////
// CREATE VS MERGE
///////////////////////////////////////////////////////////////////////////////

//
// CREATE
//
// • Always creates new data.
// • Fast.
// • Can create duplicates.
//
//
//
// MERGE
//
// • Checks first.
// • Creates only if needed.
// • Prevents duplicates.
// • Slightly slower.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// PRACTICE EXERCISES
///////////////////////////////////////////////////////////////////////////////

//
// Exercise 1
//
// Create a Movie node.
//
CREATE (:Movie {title:'Inception', year:2010});



//
// Exercise 2
//
// Create an Actor.
//
CREATE (:Person {name:'Leonardo DiCaprio'});



//
// Exercise 3
//
// Connect Actor to Movie.
//
MATCH
(a:Person {name:'Leonardo DiCaprio'}),
(m:Movie {title:'Inception'})

CREATE
(a)-[:ACTED_IN]->(m);



//
// Exercise 4
//
// Create three books in one CREATE.
//
CREATE
(:Book {title:'Book A'}),
(:Book {title:'Book B'}),
(:Book {title:'Book C'});



//
// Exercise 5
//
// Use MERGE to create only one Author.
//
MERGE
(:Author {name:'J.K. Rowling'});



//
// Exercise 6
//
// Create relationship using MERGE.
//
MATCH
(a:Author {name:'J.K. Rowling'}),
(b:Book {title:'Book A'})

MERGE
(a)-[:WROTE]->(b);



