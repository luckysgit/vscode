// Neo4j Cypher - Aggregation & Functions
// File: 07_aggregation_and_functions.cypher
//
// Topics Covered
// 1. COUNT()
// 2. SUM()
// 3. AVG()
// 4. MIN()
// 5. MAX()
// 6. COLLECT()
// 7. SIZE()
// 8. LENGTH()
// 9. TYPE()
// 10. labels()
// 11. properties()
// 12. String Functions
// 13. Numeric Functions
// 14. Date & Time Functions
// 15. COALESCE()
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// SAMPLE GRAPH
///////////////////////////////////////////////////////////////////////////////

/*

(:Person {name:'Alice', age:25, salary:70000})
(:Person {name:'Bob', age:30, salary:85000})
(:Person {name:'Charlie', age:35, salary:90000})
(:Person {name:'David', age:22, salary:60000})

(:Company {name:'Google'})
(:Company {name:'Microsoft'})

(Alice)-[:WORKS_AT]->(Google)
(Bob)-[:WORKS_AT]->(Google)
(Charlie)-[:WORKS_AT]->(Microsoft)

*/




///////////////////////////////////////////////////////////////////////////////
// 1. COUNT()
///////////////////////////////////////////////////////////////////////////////

//
// COUNT() returns the number of rows.
//
///////////////////////////////////////////////////////////////////////////////



// Count all Person nodes

MATCH (p:Person)

RETURN COUNT(p) AS TotalPersons;



// Count all Company nodes

MATCH (c:Company)

RETURN COUNT(c) AS TotalCompanies;



// Count relationships

MATCH ()-[r]->()

RETURN COUNT(r) AS TotalRelationships;



// Count distinct companies

MATCH (p)-[:WORKS_AT]->(c)

RETURN COUNT(DISTINCT c) AS Companies;



///////////////////////////////////////////////////////////////////////////////
// GROUP BY
///////////////////////////////////////////////////////////////////////////////

//
// Cypher groups automatically by non-aggregated columns.
//
///////////////////////////////////////////////////////////////////////////////

MATCH

(p)-[:WORKS_AT]->(c)

RETURN

c.name,
COUNT(p) AS Employees;



///////////////////////////////////////////////////////////////////////////////
// 2. SUM()
///////////////////////////////////////////////////////////////////////////////

//
// SUM() totals numeric values.
//
///////////////////////////////////////////////////////////////////////////////



MATCH (p:Person)

RETURN

SUM(p.salary) AS TotalSalary;



// Salary by company

MATCH

(p)-[:WORKS_AT]->(c)

RETURN

c.name,
SUM(p.salary) AS Payroll;



///////////////////////////////////////////////////////////////////////////////
// 3. AVG()
///////////////////////////////////////////////////////////////////////////////

//
// Average value.
//
///////////////////////////////////////////////////////////////////////////////



MATCH (p:Person)

RETURN

AVG(p.age) AS AverageAge;



MATCH

(p)-[:WORKS_AT]->(c)

RETURN

c.name,
AVG(p.salary) AS AverageSalary;



///////////////////////////////////////////////////////////////////////////////
// 4. MIN()
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

RETURN

MIN(p.age) AS YoungestEmployee;



MATCH (p:Person)

RETURN

MIN(p.salary) AS LowestSalary;



///////////////////////////////////////////////////////////////////////////////
// 5. MAX()
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

RETURN

MAX(p.age) AS OldestEmployee;



MATCH (p:Person)

RETURN

MAX(p.salary) AS HighestSalary;



///////////////////////////////////////////////////////////////////////////////
// 6. COLLECT()
///////////////////////////////////////////////////////////////////////////////

//
// Creates a list.
//
///////////////////////////////////////////////////////////////////////////////



MATCH (p:Person)

RETURN

COLLECT(p.name) AS Names;



// Employees by company

MATCH

(p)-[:WORKS_AT]->(c)

RETURN

c.name,
COLLECT(p.name) AS Employees;



// Distinct list

MATCH

(p)-[:WORKS_AT]->(c)

RETURN

COLLECT(DISTINCT c.name) AS Companies;



///////////////////////////////////////////////////////////////////////////////
// 7. SIZE()
///////////////////////////////////////////////////////////////////////////////

//
// Returns list length.
//
///////////////////////////////////////////////////////////////////////////////



MATCH (p:Person)

RETURN

p.name,
SIZE(p.skills) AS SkillCount;



// Number of outgoing relationships

MATCH (p:Person)

RETURN

p.name,
SIZE( (p)-->() ) AS Relationships;



///////////////////////////////////////////////////////////////////////////////
// 8. LENGTH()
///////////////////////////////////////////////////////////////////////////////

//
// Returns path length.
//
///////////////////////////////////////////////////////////////////////////////



MATCH

path=(a:Person {name:'Alice'})-[:FRIEND*]->(b)

RETURN

path,
LENGTH(path) AS Hops;



///////////////////////////////////////////////////////////////////////////////
// 9. TYPE()
///////////////////////////////////////////////////////////////////////////////

//
// Relationship type.
//
///////////////////////////////////////////////////////////////////////////////



MATCH

(a)-[r]->(b)

RETURN

type(r);



MATCH

(a)-[r]->(b)

RETURN

a.name,
type(r),
b.name;



///////////////////////////////////////////////////////////////////////////////
// 10. labels()
///////////////////////////////////////////////////////////////////////////////

//
// Returns node labels.
//
///////////////////////////////////////////////////////////////////////////////



MATCH (p)

RETURN

p.name,
labels(p);



///////////////////////////////////////////////////////////////////////////////
// Multiple labels

MATCH (n)

RETURN

labels(n);



///////////////////////////////////////////////////////////////////////////////
// 11. properties()
///////////////////////////////////////////////////////////////////////////////

//
// Returns every property.
//
///////////////////////////////////////////////////////////////////////////////



MATCH (p:Person)

RETURN

properties(p);



MATCH (c:Company)

RETURN

properties(c);



///////////////////////////////////////////////////////////////////////////////
// 12. STRING FUNCTIONS
///////////////////////////////////////////////////////////////////////////////

//
// String manipulation.
//
///////////////////////////////////////////////////////////////////////////////



// Uppercase

MATCH (p:Person)

RETURN

UPPER(p.name);



///////////////////////////////////////////////////////////////////////////////
// Lowercase
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

RETURN

LOWER(p.name);



///////////////////////////////////////////////////////////////////////////////
// Length
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

RETURN

p.name,
SIZE(p.name);



///////////////////////////////////////////////////////////////////////////////
// Left

MATCH (p:Person)

RETURN

LEFT(p.name,3);



///////////////////////////////////////////////////////////////////////////////
// Right

MATCH (p:Person)

RETURN

RIGHT(p.name,2);



///////////////////////////////////////////////////////////////////////////////
// Substring

MATCH (p:Person)

RETURN

SUBSTRING(p.name,1,3);



///////////////////////////////////////////////////////////////////////////////
// Trim

RETURN

TRIM("   Neo4j   ");



///////////////////////////////////////////////////////////////////////////////
// Replace

RETURN

REPLACE(

"Neo4j Graph Database",

"Graph",

"Network"

);



///////////////////////////////////////////////////////////////////////////////
// Reverse

RETURN

REVERSE("Cypher");



///////////////////////////////////////////////////////////////////////////////
// Split

RETURN

SPLIT(

"Python,Java,Cypher",

","

);



///////////////////////////////////////////////////////////////////////////////
// 13. NUMERIC FUNCTIONS
///////////////////////////////////////////////////////////////////////////////

//
// Mathematical operations.
//
///////////////////////////////////////////////////////////////////////////////



RETURN ABS(-50);



RETURN CEIL(12.3);



RETURN FLOOR(12.8);



RETURN ROUND(15.76);



RETURN SQRT(144);



RETURN RAND();



RETURN SIGN(-20);



RETURN PI();



RETURN SIN(PI()/2);



RETURN COS(0);



///////////////////////////////////////////////////////////////////////////////
// 14. DATE & TIME FUNCTIONS
///////////////////////////////////////////////////////////////////////////////

//
// Neo4j temporal values.
//
///////////////////////////////////////////////////////////////////////////////



RETURN date();



RETURN datetime();



RETURN localdatetime();



RETURN time();



RETURN localtime();



///////////////////////////////////////////////////////////////////////////////
// Current year

RETURN

date().year;



///////////////////////////////////////////////////////////////////////////////
// Current month

RETURN

date().month;



///////////////////////////////////////////////////////////////////////////////
// Current day

RETURN

date().day;



///////////////////////////////////////////////////////////////////////////////
// Parse date

RETURN

date("2025-12-25");



///////////////////////////////////////////////////////////////////////////////
// Duration

RETURN

duration({

days:30

});



///////////////////////////////////////////////////////////////////////////////
// 15. COALESCE()
///////////////////////////////////////////////////////////////////////////////

//
// Returns first non-null value.
//
///////////////////////////////////////////////////////////////////////////////



MATCH (p:Person)

RETURN

p.name,

COALESCE(

p.city,

"Unknown"

) AS City;



MATCH (p:Person)

RETURN

COALESCE(

p.email,

p.phone,

"No Contact"

);



///////////////////////////////////////////////////////////////////////////////
// COMBINING FUNCTIONS
///////////////////////////////////////////////////////////////////////////////

MATCH

(p)-[:WORKS_AT]->(c)

RETURN

c.name,

COUNT(*) AS Employees,

AVG(p.salary) AS AvgSalary,

MIN(p.salary) AS MinSalary,

MAX(p.salary) AS MaxSalary,

COLLECT(p.name) AS EmployeeNames;



///////////////////////////////////////////////////////////////////////////////
// PRACTICE EXERCISES
///////////////////////////////////////////////////////////////////////////////

//
// Exercise 1
// Count all persons.
//
MATCH (p:Person)

RETURN COUNT(p);



//
// Exercise 2
// Average salary.
//
MATCH (p:Person)

RETURN AVG(p.salary);



//
// Exercise 3
// Highest salary.
//
MATCH (p:Person)

RETURN MAX(p.salary);



//
// Exercise 4
// Collect names.
//
MATCH (p:Person)

RETURN COLLECT(p.name);



//
// Exercise 5
// Relationship type.
//
MATCH ()-[r]->()

RETURN type(r);



//
// Exercise 6
// Labels.
//
MATCH (n)

RETURN labels(n);



//
// Exercise 7
// Uppercase names.
//
MATCH (p:Person)

RETURN UPPER(p.name);



//
// Exercise 8
// Current date.
//
RETURN date();



//
// Exercise 9
// Replace null city.
//
MATCH (p:Person)

RETURN

COALESCE(p.city,"Unknown");



//
// Exercise 10
// Employee count by company.
//
MATCH

(p)-[:WORKS_AT]->(c)

RETURN

c.name,

COUNT(p);



