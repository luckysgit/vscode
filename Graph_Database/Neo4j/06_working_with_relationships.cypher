///////////////////////////////////////////////////////////////////////////////
// Neo4j Cypher - Working with Relationships
// File: 06_working_with_relationships.cypher
//
// Topics Covered
// 1. Directed Relationships
// 2. Undirected Relationships
// 3. Relationship Properties
// 4. Relationship Types
// 5. Variable Length Relationships
// 6. shortestPath()
// 7. allShortestPaths()
// 8. Relationship Patterns
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// SAMPLE GRAPH
///////////////////////////////////////////////////////////////////////////////

/*

(Alice)-[:FRIEND {since:2020}]->(Bob)
(Bob)-[:FRIEND {since:2019}]->(Charlie)
(Charlie)-[:FRIEND {since:2021}]->(David)
(David)-[:FRIEND {since:2022}]->(Emma)

(Alice)-[:WORKS_AT]->(Google)
(Bob)-[:WORKS_AT]->(Google)
(Charlie)-[:WORKS_AT]->(Microsoft)

(Google)-[:LOCATED_IN]->(London)
(Microsoft)-[:LOCATED_IN]->(Seattle)

*/




///////////////////////////////////////////////////////////////////////////////
// 1. DIRECTED RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

//
// Relationships have directions.
//
// (A)-[:TYPE]->(B)
//
// Direction matters.
//
///////////////////////////////////////////////////////////////////////////////



// Find outgoing FRIEND relationships

MATCH

(a:Person)-[:FRIEND]->(b:Person)

RETURN

a,
b;



// Find outgoing WORKS_AT relationships

MATCH

(person)-[:WORKS_AT]->(company)

RETURN

person,
company;



// Store relationship variable

MATCH

(a)-[r:FRIEND]->(b)

RETURN

a,
r,
b;



///////////////////////////////////////////////////////////////////////////////
// REVERSE DIRECTION
///////////////////////////////////////////////////////////////////////////////

//
// Incoming relationships.
//
///////////////////////////////////////////////////////////////////////////////

MATCH

(company)<-[:WORKS_AT]-(person)

RETURN

company,
person;



MATCH

(b)<-[:FRIEND]-(a)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// 2. UNDIRECTED RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

//
// Ignore relationship direction.
//
// Syntax:
//
// (a)--(b)
//
///////////////////////////////////////////////////////////////////////////////



// Any relationship

MATCH

(a)--(b)

RETURN

a,
b;



// FRIEND regardless of direction

MATCH

(a)-[:FRIEND]-(b)

RETURN

a,
b;



// WORKS_AT regardless of direction

MATCH

(person)-[:WORKS_AT]-(company)

RETURN

person,
company;



///////////////////////////////////////////////////////////////////////////////
// 3. RELATIONSHIP PROPERTIES
///////////////////////////////////////////////////////////////////////////////

//
// Relationships can have properties.
//
// Example:
//
// [:FRIEND {
//      since:2020,
//      strength:8
// }]
//
///////////////////////////////////////////////////////////////////////////////



// Create relationship with properties

MATCH

(a:Person {name:'Alice'}),

(b:Person {name:'Bob'})

CREATE

(a)-[:FRIEND {

    since:2020,
    strength:10,
    status:'Best Friends'

}]->(b);



///////////////////////////////////////////////////////////////////////////////
// RETURN RELATIONSHIP PROPERTIES
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[r:FRIEND]->(b)

RETURN

a.name,
r.since,
r.strength,
r.status,
b.name;



///////////////////////////////////////////////////////////////////////////////
// FILTER BY RELATIONSHIP PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[r:FRIEND]->(b)

WHERE

r.since >= 2020

RETURN

a,
b,
r;



///////////////////////////////////////////////////////////////////////////////
// UPDATE RELATIONSHIP PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[r:FRIEND]->(b)

SET

r.strength = 9

RETURN r;



///////////////////////////////////////////////////////////////////////////////
// REMOVE RELATIONSHIP PROPERTY
///////////////////////////////////////////////////////////////////////////////

MATCH

()-[r:FRIEND]->()

REMOVE

r.status

RETURN r;



///////////////////////////////////////////////////////////////////////////////
// 4. RELATIONSHIP TYPES
///////////////////////////////////////////////////////////////////////////////

//
// Relationships are identified by TYPE.
//
///////////////////////////////////////////////////////////////////////////////



// WORKS_AT

MATCH

(p)-[:WORKS_AT]->(c)

RETURN

p,
c;



// FRIEND

MATCH

(a)-[:FRIEND]->(b)

RETURN

a,
b;



// KNOWS

MATCH

(a)-[:KNOWS]->(b)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// MULTIPLE RELATIONSHIP TYPES
///////////////////////////////////////////////////////////////////////////////

//
// Match either FRIEND or KNOWS.
//
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[:FRIEND|KNOWS]->(b)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// ANY RELATIONSHIP TYPE
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[r]->(b)

RETURN

a,
type(r),
b;



///////////////////////////////////////////////////////////////////////////////
// RELATIONSHIP TYPE FUNCTION
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[r]->(b)

RETURN

type(r);



///////////////////////////////////////////////////////////////////////////////
// 5. VARIABLE LENGTH RELATIONSHIPS
///////////////////////////////////////////////////////////////////////////////

//
// Traverse multiple hops.
//
// Syntax:
//
// *min..max
//
///////////////////////////////////////////////////////////////////////////////



// One to three FRIEND hops

MATCH

(a:Person {name:'Alice'})

-[:FRIEND*1..3]->

(friend)

RETURN friend;



///////////////////////////////////////////////////////////////////////////////
// ANY NUMBER OF HOPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(start)

-[:FRIEND*]->

(end)

RETURN

start,
end;



///////////////////////////////////////////////////////////////////////////////
// EXACTLY TWO HOPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)

-[:FRIEND*2]->

(b)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// RANGE OF HOPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)

-[:FRIEND*2..5]->

(b)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// STORE COMPLETE PATH
///////////////////////////////////////////////////////////////////////////////

MATCH

path =

(a)

-[:FRIEND*1..4]->

(b)

RETURN

path;



///////////////////////////////////////////////////////////////////////////////
// 6. SHORTEST PATH
///////////////////////////////////////////////////////////////////////////////

//
// Finds one shortest path.
//
///////////////////////////////////////////////////////////////////////////////



MATCH

(a:Person {name:'Alice'}),

(b:Person {name:'Emma'})

MATCH

path = shortestPath(

(a)-[:FRIEND*]-(b)

)

RETURN

path;



///////////////////////////////////////////////////////////////////////////////
// SHORTEST PATH WITH DIRECTION
///////////////////////////////////////////////////////////////////////////////

MATCH

(a:Person {name:'Alice'}),

(b:Person {name:'David'})

RETURN

shortestPath(

(a)-[:FRIEND*]->(b)

);



///////////////////////////////////////////////////////////////////////////////
// SHORTEST PATH LENGTH
///////////////////////////////////////////////////////////////////////////////

MATCH

(a:Person {name:'Alice'}),

(b:Person {name:'David'})

RETURN

length(

shortestPath(

(a)-[:FRIEND*]->(b)

)

) AS NumberOfHops;



///////////////////////////////////////////////////////////////////////////////
// 7. allShortestPaths()
///////////////////////////////////////////////////////////////////////////////

//
// Returns every shortest path.
//
// Useful when multiple shortest paths exist.
//
///////////////////////////////////////////////////////////////////////////////



MATCH

(a:Person {name:'Alice'}),

(b:Person {name:'Emma'})

MATCH

path =

allShortestPaths(

(a)-[:FRIEND*]-(b)

)

RETURN

path;



///////////////////////////////////////////////////////////////////////////////
// RETURN PATH LENGTH
///////////////////////////////////////////////////////////////////////////////

MATCH

(a:Person {name:'Alice'}),

(b:Person {name:'Emma'})

MATCH

path =

allShortestPaths(

(a)-[:FRIEND*]-(b)

)

RETURN

length(path),
path;



///////////////////////////////////////////////////////////////////////////////
// 8. RELATIONSHIP PATTERNS
///////////////////////////////////////////////////////////////////////////////

//
// Complex graph traversal.
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// PERSON -> COMPANY
///////////////////////////////////////////////////////////////////////////////

MATCH

(person)

-[:WORKS_AT]->

(company)

RETURN

person,
company;



///////////////////////////////////////////////////////////////////////////////
// PERSON -> COMPANY -> CITY
///////////////////////////////////////////////////////////////////////////////

MATCH

(person)

-[:WORKS_AT]->

(company)

-[:LOCATED_IN]->

(city)

RETURN

person,
company,
city;



///////////////////////////////////////////////////////////////////////////////
// FRIEND -> COMPANY
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)

-[:FRIEND]->

(friend)

-[:WORKS_AT]->

(company)

RETURN

a,
friend,
company;



///////////////////////////////////////////////////////////////////////////////
// COMPLETE PATH
///////////////////////////////////////////////////////////////////////////////

MATCH

path=

(a)

-[:FRIEND]->

(b)

-[:WORKS_AT]->

(c)

RETURN

path;



///////////////////////////////////////////////////////////////////////////////
// MULTIPLE RELATIONSHIP TYPES
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)

-[:FRIEND|KNOWS]->

(b)

-[:WORKS_AT]->

(company)

RETURN

a,
b,
company;



///////////////////////////////////////////////////////////////////////////////
// MIXED DIRECTION PATTERN
///////////////////////////////////////////////////////////////////////////////

MATCH

(person)

-[:WORKS_AT]->

(company)

<-[:WORKS_AT]-

(colleague)

RETURN

person,
colleague,
company;



///////////////////////////////////////////////////////////////////////////////
// FIND COLLEAGUES
///////////////////////////////////////////////////////////////////////////////

MATCH

(a:Person)

-[:WORKS_AT]->

(c:Company)

<-[:WORKS_AT]-

(b:Person)

WHERE a <> b

RETURN

a.name,
b.name,
c.name;



///////////////////////////////////////////////////////////////////////////////
// PRACTICE EXERCISES
///////////////////////////////////////////////////////////////////////////////

//
// Exercise 1
// Return every FRIEND relationship.
//
MATCH

(a)-[:FRIEND]->(b)

RETURN

a,
b;



//
// Exercise 2
// Return every relationship.
//
MATCH

(a)-[r]->(b)

RETURN

a,
type(r),
b;



//
// Exercise 3
// Find people working at Google.
//
MATCH

(p)-[:WORKS_AT]->

(c:Company {name:'Google'})

RETURN p;



//
// Exercise 4
// Find friends of friends.
//
MATCH

(a)

-[:FRIEND*2]->

(b)

RETURN

a,
b;



//
// Exercise 5
// Find colleagues.
//
MATCH

(a)-[:WORKS_AT]->

(c)

<-[:WORKS_AT]-

(b)

WHERE a <> b

RETURN

a,
b;



//
// Exercise 6
// Return relationship properties.
//
MATCH

(a)-[r:FRIEND]->(b)

RETURN

r.since,
r.strength;



//
// Exercise 7
// Shortest path.
//
MATCH

(a:Person {name:'Alice'}),

(b:Person {name:'Emma'})

RETURN

shortestPath(

(a)-[:FRIEND*]-(b)

);



///////////////////////////////////////////////////////////////////////////////
// CHEAT SHEET
///////////////////////////////////////////////////////////////////////////////

//
// Directed
//
// (a)-[:TYPE]->(b)
//
//
//
// Reverse
//
// (a)<-[:TYPE]-(b)
//
//
//
// Undirected
//
// (a)-[:TYPE]-(b)
//
//
//
// Any Relationship
//
// (a)--(b)
//
//
//
// Multiple Types
//
// [:FRIEND|KNOWS]
//
//
//
// Relationship Variable
//
// [r:TYPE]
//
//
//
// Property
//
// r.since
//
//
//
// Variable Length
//
// *1..3
//
// *2
//
// *
//
//
//
// Shortest Path
//
// shortestPath()
//
//
//
// All Shortest Paths
//
// allShortestPaths()
//
//
//
// Relationship Type
//
// type(r)
//
//
//
// Path Length
//
// length(path)
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// END OF FILE
///////////////////////////////////////////////////////////////////////////////