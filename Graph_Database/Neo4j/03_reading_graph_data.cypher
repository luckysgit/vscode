///////////////////////////////////////////////////////////////////////////////
// Neo4j Cypher - Reading Graph Data (MATCH)
// File: 03_reading_graph_data.cypher
//
// Topics Covered
// 1. MATCH
// 2. Pattern Matching
// 3. Node Matching
// 4. Relationship Matching
// 5. Multi-Hop Matching
// 6. Variable Length Paths
// 7. OPTIONAL MATCH
// 8. Pattern Expressions
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// SAMPLE GRAPH
///////////////////////////////////////////////////////////////////////////////

/*

(Person: Alice) --------FRIEND-------> (Bob)
      |
      | WORKS_AT
      |
      v
   (Google)

(Bob) --------WORKS_AT-------> (Google)

(Bob) --------FRIEND---------> (Charlie)

(Charlie) -----WORKS_AT------> (Microsoft)

*/




///////////////////////////////////////////////////////////////////////////////
// 1. MATCH
///////////////////////////////////////////////////////////////////////////////

//
// MATCH is used to retrieve data from the graph.
//
// Syntax:
//
// MATCH (pattern)
// RETURN result;
//
// Similar to SQL SELECT.
//
///////////////////////////////////////////////////////////////////////////////



// Return every node

MATCH (n)
RETURN n;



// Return all Person nodes

MATCH (p:Person)
RETURN p;



// Return all Company nodes

MATCH (c:Company)
RETURN c;



///////////////////////////////////////////////////////////////////////////////
// MATCH WITH VARIABLES
///////////////////////////////////////////////////////////////////////////////

MATCH (person:Person)
RETURN person;



MATCH (company:Company)
RETURN company;



///////////////////////////////////////////////////////////////////////////////
// RETURN SPECIFIC PROPERTIES
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

RETURN

p.name,
p.age;



///////////////////////////////////////////////////////////////////////////////
// 2. PATTERN MATCHING
///////////////////////////////////////////////////////////////////////////////

//
// Cypher searches using graph patterns.
//
// General pattern:
//
// (node)-[relationship]->(node)
//
///////////////////////////////////////////////////////////////////////////////



// Find all WORKS_AT relationships

MATCH

(p:Person)-[:WORKS_AT]->(c:Company)

RETURN

p,
c;



// Find all FRIEND relationships

MATCH

(a:Person)-[:FRIEND]->(b:Person)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// MATCH ANY RELATIONSHIP
///////////////////////////////////////////////////////////////////////////////

//
// [] means any relationship.
//
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[]->(b)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// MATCH ANY DIRECTION
///////////////////////////////////////////////////////////////////////////////

//
// --
// means relationship in either direction.
//
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)--(b)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// 3. NODE MATCHING
///////////////////////////////////////////////////////////////////////////////

//
// Match nodes based on labels.
//
///////////////////////////////////////////////////////////////////////////////



// Every Person

MATCH (p:Person)

RETURN p;



// Every Employee

MATCH (e:Employee)

RETURN e;



// Every Company

MATCH (c:Company)

RETURN c;



///////////////////////////////////////////////////////////////////////////////
// MATCH NODE USING PROPERTIES
///////////////////////////////////////////////////////////////////////////////

MATCH

(p:Person {name:'Alice'})

RETURN p;



MATCH

(c:Company {name:'Google'})

RETURN c;



///////////////////////////////////////////////////////////////////////////////
// MULTIPLE NODE MATCHING
///////////////////////////////////////////////////////////////////////////////

MATCH

(a:Person),

(c:Company)

RETURN

a,
c;



///////////////////////////////////////////////////////////////////////////////
// 4. RELATIONSHIP MATCHING
///////////////////////////////////////////////////////////////////////////////

//
// Relationships connect nodes.
//
///////////////////////////////////////////////////////////////////////////////



// Match WORKS_AT

MATCH

(person)-[:WORKS_AT]->(company)

RETURN

person,
company;



// Match FRIEND

MATCH

(a)-[:FRIEND]->(b)

RETURN

a,
b;



// Store relationship in a variable

MATCH

(a)-[r:FRIEND]->(b)

RETURN

a,
r,
b;



///////////////////////////////////////////////////////////////////////////////
// RELATIONSHIP PROPERTIES
///////////////////////////////////////////////////////////////////////////////

//
// Suppose:
//
// [:FRIEND {since:2020}]
//
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[r:FRIEND]->(b)

RETURN

a.name,
r.since,
b.name;



///////////////////////////////////////////////////////////////////////////////
// ANY RELATIONSHIP TYPE
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)-[r]->(b)

RETURN

a,
type(r),
b;



///////////////////////////////////////////////////////////////////////////////
// 5. MULTI-HOP MATCHING
///////////////////////////////////////////////////////////////////////////////

//
// Match across multiple relationships.
//
///////////////////////////////////////////////////////////////////////////////



// Person -> Company -> City

MATCH

(p:Person)

-[:WORKS_AT]->

(c:Company)

-[:LOCATED_IN]->

(city:City)

RETURN

p,
c,
city;



///////////////////////////////////////////////////////////////////////////////
// THREE HOPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)

-->(b)

-->(c)

-->(d)

RETURN

a,
b,
c,
d;



///////////////////////////////////////////////////////////////////////////////
// CHAINED FRIENDSHIPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(a:Person)

-[:FRIEND]->

(b:Person)

-[:FRIEND]->

(c:Person)

RETURN

a,
b,
c;



///////////////////////////////////////////////////////////////////////////////
// 6. VARIABLE LENGTH PATHS
///////////////////////////////////////////////////////////////////////////////

//
// Syntax
//
// *1..3
//
// Means:
//
// Minimum 1 hop
// Maximum 3 hops
//
///////////////////////////////////////////////////////////////////////////////



// Friends up to three levels

MATCH

(p:Person {name:'Alice'})

-[:FRIEND*1..3]->

(friend)

RETURN friend;



///////////////////////////////////////////////////////////////////////////////
// ANY NUMBER OF HOPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(start:Person)

-[:FRIEND*]->

(end)

RETURN

start,
end;



///////////////////////////////////////////////////////////////////////////////
// EXACTLY TWO HOPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)

-[:FRIEND*2]->

(b)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// RANGE OF HOPS
///////////////////////////////////////////////////////////////////////////////

MATCH

(a)

-[:FRIEND*2..5]->

(b)

RETURN

a,
b;



///////////////////////////////////////////////////////////////////////////////
// STORE COMPLETE PATH
///////////////////////////////////////////////////////////////////////////////

MATCH

path=

(a)

-[:FRIEND*1..4]->

(b)

RETURN

path;



///////////////////////////////////////////////////////////////////////////////
// 7. OPTIONAL MATCH
///////////////////////////////////////////////////////////////////////////////

//
// OPTIONAL MATCH
//
// Similar to SQL LEFT OUTER JOIN.
//
// If pattern doesn't exist:
//
// returns NULL
//
///////////////////////////////////////////////////////////////////////////////



// Everyone with company

MATCH

(p:Person)

OPTIONAL MATCH

(p)-[:WORKS_AT]->(c)

RETURN

p.name,
c.name;



///////////////////////////////////////////////////////////////////////////////
// OPTIONAL FRIEND
///////////////////////////////////////////////////////////////////////////////

MATCH

(p:Person)

OPTIONAL MATCH

(p)-[:FRIEND]->(friend)

RETURN

p.name,
friend.name;



///////////////////////////////////////////////////////////////////////////////
// OPTIONAL CITY
///////////////////////////////////////////////////////////////////////////////

MATCH

(c:Company)

OPTIONAL MATCH

(c)-[:LOCATED_IN]->(city)

RETURN

c.name,
city.name;



///////////////////////////////////////////////////////////////////////////////
// 8. PATTERN EXPRESSIONS
///////////////////////////////////////////////////////////////////////////////

//
// Pattern expressions allow checking whether
// relationships exist.
//
///////////////////////////////////////////////////////////////////////////////



// Return all people who have outgoing FRIEND relationship

MATCH (p:Person)

WHERE (p)-[:FRIEND]->()

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// Incoming relationship
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE ()-[:FRIEND]->(p)

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// Has WORKS_AT relationship
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE (p)-[:WORKS_AT]->(:Company)

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// Count relationships
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

RETURN

p.name,

size( (p)-->() ) AS OutgoingRelationships;



///////////////////////////////////////////////////////////////////////////////
// Find isolated nodes
///////////////////////////////////////////////////////////////////////////////

MATCH (p:Person)

WHERE NOT (p)--()

RETURN p;



///////////////////////////////////////////////////////////////////////////////
// MATCH COMPLETE PATH
///////////////////////////////////////////////////////////////////////////////

MATCH

path=

(a:Person)

-[:FRIEND]->

(b:Person)

-[:WORKS_AT]->

(c:Company)

RETURN

path;



///////////////////////////////////////////////////////////////////////////////
// PRACTICE EXERCISES
///////////////////////////////////////////////////////////////////////////////

//
// Exercise 1
// Return every Movie.
//
MATCH (m:Movie)
RETURN m;



//
// Exercise 2
// Return every Author.
//
MATCH (a:Author)
RETURN a;



//
// Exercise 3
// Return every BOOK written by an Author.
//
MATCH

(a:Author)-[:WROTE]->(b:Book)

RETURN

a,
b;



//
// Exercise 4
// Find all FRIEND relationships.
//
MATCH

(a)-[:FRIEND]->(b)

RETURN

a,
b;



//
// Exercise 5
// Find friends of friends.
//
MATCH

(a)

-[:FRIEND*2]->

(b)

RETURN

a,
b;



//
// Exercise 6
// Find every person even if they don't work anywhere.
//
MATCH

(p:Person)

OPTIONAL MATCH

(p)-[:WORKS_AT]->(c)

RETURN

p.name,
c.name;



//
// Exercise 7
// Return complete paths.
//
MATCH

path=(a)-->(b)

RETURN

path;



///////////////////////////////////////////////////////////////////////////////
// COMMON MATCH PATTERNS
///////////////////////////////////////////////////////////////////////////////

//
// Every node
//
// MATCH (n)
//
//
//
// Every Person
//
// MATCH (p:Person)
//
//
//
// Person by property
//
// MATCH (p:Person {name:'Alice'})
//
//
//
// Person -> Company
//
// MATCH (p)-[:WORKS_AT]->(c)
//
//
//
// Any relationship
//
// MATCH (a)-[]->(b)
//
//
//
// Any direction
//
// MATCH (a)--(b)
//
//
//
// Variable path
//
// MATCH (a)-[:FRIEND*1..3]->(b)
//
//
//
// Optional relationship
//
// OPTIONAL MATCH
//
//
//
// Store path
//
// MATCH path=(a)-->(b)
//
///////////////////////////////////////////////////////////////////////////////



///////////////////////////////////////////////////////////////////////////////
// END OF FILE
///////////////////////////////////////////////////////////////////////////////